{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist/todo-list/browser"
      }
    }
  ],
  "routes": [
    {
      "src": "^/(?!.*\\.\\w+$).*$",
      "destination": "/index.html"
    },
    {
      "src": "/.*",
      "methods": ["GET"],
      "destination": "/index.html"
    }
  ],
  "buildCommand": "npm run build",
  "outputDirectory": "dist/todo-list/browser",
  "framework": "angular"
}
